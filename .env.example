# --- /chat (see app/api/chat/route.ts) ---

# ClawRouter API key (OpenAI-compatible gateway). Chat returns 503 until set.
CLAWROUTER_API_KEY=
# Defaults: https://clawrouter.com and gemini-3.5-flash (verified working
# 2026-07; the account has NO deepseek models — check GET /v1/models).
# CLAWROUTER_BASE_URL=https://clawrouter.com
# CHAT_MODEL=gemini-3.5-flash

# Upstash Redis (REST) — persistent daily rate limits + conversation/lead log.
# Without it, limits fall back to per-process memory (weak on Vercel).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Daily caps (defaults shown)
# CHAT_LIMIT_EMAIL=10
# CHAT_LIMIT_IP=30
# CHAT_LIMIT_GLOBAL=500

# Telegram lead notifications: create a bot via @BotFather, message it once,
# get your chat id from https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
