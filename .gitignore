# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.gstack/

# private author notes (GTM / product strategy — never publish)
*.notes.md

# private writing memory / voice transcripts — never publish
content/writing-memory/*.private.md

# situational / product memory for agents only — never public git
# (prep for /ask + Gita; do NOT ship into content/persona/ either)
docs/context/howard-memory.md

# local agent skill host links (absolute paths break on other machines)
.codex/
.grok/

# write-blog scratch / unshipped fig sources
.tmp-write-blog-cpu-gpu/

# raw persona sources (PDFs etc.) — only converted .md in content/persona/ ships
content/persona/src/
# regenerated on every build by scripts/github-activity.mjs
content/persona/github-activity.md

# background shard worktrees (worker scratch, auto-removed on land)
.claude/worktrees/
